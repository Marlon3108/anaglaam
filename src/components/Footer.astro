---
// src/components/Footer.astro
---

<footer class="bg-[#1A0000] relative overflow-hidden">

  <!-- Fondo puntillado -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]"
       style="background-image: radial-gradient(#FAF4D4 1px, transparent 1px); background-size: 20px 20px;">
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <!-- Top footer -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 py-16 border-b border-[#FAF4D4]/10">

      <!-- Col 1: Branding -->
      <div class="flex flex-col gap-4">
        <a href="/" class="font-lobster text-4xl text-[#FAF4D4] hover:text-[#DF8F9C]
                           transition-colors duration-300 self-start">
          anaglaam
        </a>
        <p class="font-inter text-[#FAF4D4]/50 text-sm leading-relaxed">
          UGC Creator especializada en belleza. Venezolana en Cali, Colombia.
          Contenido auténtico para marcas reales.
        </p>
        <!-- Redes -->
        <div class="flex gap-3 mt-2">
          <a href="https://instagram.com/anaglaam" target="_blank" rel="noopener noreferrer"
             aria-label="Instagram Ana Glaam"
             class="w-10 h-10 rounded-xl bg-[#FAF4D4]/08 flex items-center justify-center
                    text-[#FAF4D4]/60 hover:bg-[#DF8F9C] hover:text-[#1A0000]
                    transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://tiktok.com/@anaglam8" target="_blank" rel="noopener noreferrer"
             aria-label="TikTok Ana Glaam"
             class="w-10 h-10 rounded-xl bg-[#FAF4D4]/08 flex items-center justify-center
                    text-[#FAF4D4]/60 hover:bg-[#DF8F9C] hover:text-[#1A0000]
                    transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.53V6.75a4.85 4.85 0 01-1.02-.06z"/>
            </svg>
          </a>
          <a href="mailto:anaglaam@gmail.com"
             aria-label="Email Ana Glaam"
             class="w-10 h-10 rounded-xl bg-[#FAF4D4]/08 flex items-center justify-center
                    text-[#FAF4D4]/60 hover:bg-[#DF8F9C] hover:text-[#1A0000]
                    transition-all duration-300">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Navegación -->
      <div class="flex flex-col gap-4">
        <p class="font-inter text-xs font-semibold tracking-[0.2em] uppercase text-[#DF8F9C]">
          Navegación
        </p>
        <ul class="flex flex-col gap-3">
          {[
            { label: 'Inicio',          href: '#inicio' },
            { label: 'Sobre mí',        href: '#sobre-mi' },
            { label: '¿Qué es UGC?',    href: '#que-es-ugc' },
            { label: 'Servicios',       href: '#servicios' },
            { label: 'Estadísticas',    href: '#stats' },
            { label: 'Portafolio',      href: '#portafolio' },
            { label: 'Colaboraciones',  href: '#colaboraciones' },
            { label: 'Contacto',        href: '#contacto' },
          ].map(({ label, href }) => (
            <li>
              <a href={href}
                 class="font-inter text-sm text-[#FAF4D4]/50
                        hover:text-[#DF8F9C] transition-colors duration-300">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Servicios -->
      <div class="flex flex-col gap-4">
        <p class="font-inter text-xs font-semibold tracking-[0.2em] uppercase text-[#DF8F9C]">
          Servicios
        </p>
        <ul class="flex flex-col gap-3">
          {[
            '💄 Makeup UGC',
            '🧴 Skincare',
            '💅 Nail Content',
            '🌀 Curly Hair',
            '👗 Moda & Accesorios',
            '📦 Unboxing',
          ].map(service => (
            <li class="font-inter text-sm text-[#FAF4D4]/50">{service}</li>
          ))}
        </ul>
        <a
          href="#contacto"
          class="mt-2 self-start font-inter text-xs font-semibold text-[#660005]
                 bg-[#660005]/20 px-4 py-2 rounded-full hover:bg-[#660005]
                 hover:text-[#FAF4D4] transition-all duration-300"
        >
          Solicitar cotización →
        </a>
      </div>
    </div>

    <!-- Bottom footer -->
    <div class="flex flex-col md:flex-row items-center justify-between
                gap-3 py-6 text-[#FAF4D4]/30 text-xs font-inter">
      <p>© 2026 Ana Dávila · anaglaam · Cali, Colombia. Todos los derechos reservados.</p>
      <p>Hecho con ❤️ para marcas que quieren contar historias reales.</p>
    </div>
  </div>
</footer>