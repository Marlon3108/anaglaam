---
// src/components/ContactForm.astro
---

<section id="contacto" class="relative py-24 bg-[#FAF4D4] overflow-hidden">

  <div class="absolute top-0 right-0 w-[400px] h-[400px] rounded-full
              bg-[#DF8F9C]/20 blur-[100px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full
              bg-[#660005]/08 blur-[80px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Izquierda: info de contacto -->
      <div class="flex flex-col gap-8" data-aos="fade-right">

        <div>
          <span class="font-inter text-xs font-semibold tracking-[0.25em] uppercase text-[#DF8F9C]">
            Hablemos
          </span>
          <h2 class="font-bebas text-[#1A0000] mt-2 leading-none"
              style="font-size: clamp(2.8rem, 5vw, 4.5rem);">
            ¿Lista para<br/>
            <span class="text-[#660005]">colaborar?</span>
          </h2>
          <p class="font-inter text-[#1A0000]/60 mt-4 leading-relaxed">
            Cuéntame sobre tu marca y qué tipo de contenido necesitas.
            Respondo en menos de 24 horas.
          </p>
        </div>

        <!-- Canales directos -->
        <div class="flex flex-col gap-4">
          {[
            {
              icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                       <path stroke-linecap="round" stroke-linejoin="round"
                             d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                     </svg>`,
              label: 'Email',
              value: 'anaglaam@gmail.com',
              href: 'mailto:anaglaam@gmail.com',
            },
            {
              icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                       <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                     </svg>`,
              label: 'Instagram',
              value: '@anaglaam',
              href: 'https://instagram.com/anaglaam',
            },
            {
              icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                       <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.53V6.75a4.85 4.85 0 01-1.02-.06z"/>
                     </svg>`,
              label: 'TikTok',
              value: '@anaglam8',
              href: 'https://tiktok.com/@anaglam8',
            },
          ].map(({ icon, label, value, href }) => (
            <a
              href={href}
              target={href.startsWith('http') ? '_blank' : undefined}
              rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="flex items-center gap-4 bg-white rounded-2xl px-5 py-4
                     border border-[#DF8F9C]/20 shadow-[0_2px_12px_rgba(102,0,5,0.06)]
                     hover:shadow-[0_6px_24px_rgba(102,0,5,0.12)]
                     hover:border-[#DF8F9C]/50 hover:-translate-y-0.5
                     transition-all duration-300 group"
            >
              <div class="w-10 h-10 rounded-xl bg-[#FAF4D4] flex items-center justify-center
                          text-[#660005] group-hover:bg-[#660005] group-hover:text-[#FAF4D4]
                          transition-colors duration-300 shrink-0"
                   set:html={icon}>
              </div>
              <div>
                <p class="font-inter text-[10px] font-semibold uppercase tracking-widest
                          text-[#1A0000]/40">{label}</p>
                <p class="font-inter font-semibold text-sm text-[#1A0000]
                          group-hover:text-[#660005] transition-colors duration-300">
                  {value}
                </p>
              </div>
              <svg class="w-4 h-4 text-[#660005]/30 group-hover:text-[#660005] ml-auto
                          group-hover:translate-x-1 transition-all duration-300"
                   fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          ))}
        </div>

        <!-- Tiempo de respuesta -->
        <div class="flex items-center gap-3 bg-[#660005]/08 rounded-2xl px-5 py-4">
          <span class="text-2xl">⚡</span>
          <p class="font-inter text-sm text-[#660005]">
            <strong>Respuesta en menos de 24h.</strong> Ana revisa mensajes todos los días.
          </p>
        </div>
      </div>

      <!-- Derecha: formulario -->
      <div data-aos="fade-left" data-aos-delay="100">
        <form
          id="contact-form"
          action="https://formspree.io/f/mdayavvr"
          method="POST"
          class="bg-white rounded-3xl p-8 border border-[#DF8F9C]/20
                 shadow-[0_8px_40px_rgba(102,0,5,0.08)] flex flex-col gap-5"
        >
          <!-- Nombre -->
          <div class="flex flex-col gap-1.5">
            <label class="font-inter text-xs font-semibold text-[#1A0000]/60 uppercase tracking-wider">
              Nombre *
            </label>
            <input
              type="text"
              name="nombre"
              required
              placeholder="Tu nombre o empresa"
              class="font-inter text-sm text-[#1A0000] bg-[#FAF4D4]/50
                     border border-[#DF8F9C]/30 rounded-xl px-4 py-3
                     focus:outline-none focus:border-[#660005] focus:bg-white
                     placeholder:text-[#1A0000]/30 transition-all duration-300"
            />
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1.5">
            <label class="font-inter text-xs font-semibold text-[#1A0000]/60 uppercase tracking-wider">
              Email *
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="tu@marca.com"
              class="font-inter text-sm text-[#1A0000] bg-[#FAF4D4]/50
                     border border-[#DF8F9C]/30 rounded-xl px-4 py-3
                     focus:outline-none focus:border-[#660005] focus:bg-white
                     placeholder:text-[#1A0000]/30 transition-all duration-300"
            />
          </div>

          <!-- Tipo de contenido -->
          <div class="flex flex-col gap-1.5">
            <label class="font-inter text-xs font-semibold text-[#1A0000]/60 uppercase tracking-wider">
              Tipo de contenido
            </label>
            <select
              name="tipo_contenido"
              class="font-inter text-sm text-[#1A0000] bg-[#FAF4D4]/50
                     border border-[#DF8F9C]/30 rounded-xl px-4 py-3
                     focus:outline-none focus:border-[#660005] focus:bg-white
                     transition-all duration-300 cursor-pointer"
            >
              <option value="">Selecciona una opción</option>
              <option value="makeup">💄 Makeup</option>
              <option value="skincare">🧴 Skincare</option>
              <option value="nails">💅 Nails</option>
              <option value="curly">🌀 Curly Hair</option>
              <option value="moda">👗 Moda</option>
              <option value="unboxing">📦 Unboxing</option>
              <option value="otro">✨ Otro</option>
            </select>
          </div>

          <!-- Mensaje -->
          <div class="flex flex-col gap-1.5">
            <label class="font-inter text-xs font-semibold text-[#1A0000]/60 uppercase tracking-wider">
              Cuéntame sobre tu marca *
            </label>
            <textarea
              name="mensaje"
              required
              rows="4"
              placeholder="¿Qué producto tienes? ¿Qué tipo de contenido necesitas? ¿Tienes fecha límite?"
              class="font-inter text-sm text-[#1A0000] bg-[#FAF4D4]/50
                     border border-[#DF8F9C]/30 rounded-xl px-4 py-3
                     focus:outline-none focus:border-[#660005] focus:bg-white
                     placeholder:text-[#1A0000]/30 transition-all duration-300
                     resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-[#660005] text-[#FAF4D4] font-inter font-semibold
                   py-4 rounded-xl text-sm hover:bg-[#1A0000]
                   transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]
                   shadow-[0_4px_16px_rgba(102,0,5,0.3)]
                   flex items-center justify-center gap-2"
          >
            <span id="btn-text">Enviar mensaje</span>
            <svg id="btn-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>

          <!-- Mensaje de éxito/error -->
          <div id="form-feedback" class="hidden text-center text-sm font-inter py-2 rounded-xl"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const btnText  = document.getElementById('btn-text')!;
  const btnIcon  = document.getElementById('btn-icon')!;
  const feedback = document.getElementById('form-feedback')!;
  const btn      = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Loading state
    btn.disabled = true;
    btnText.textContent = 'Enviando...';
    btnIcon.innerHTML = `<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
    </svg>`;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        feedback.textContent = '✅ ¡Mensaje enviado! Ana te responde en menos de 24h.';
        feedback.className = 'text-center text-sm font-inter py-3 rounded-xl bg-green-50 text-green-700';
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      feedback.textContent = '❌ Algo salió mal. Escríbenos directo a anaglaam@gmail.com';
      feedback.className = 'text-center text-sm font-inter py-3 rounded-xl bg-red-50 text-red-700';
    } finally {
      btn.disabled = false;
      btnText.textContent = 'Enviar mensaje';
      btnIcon.innerHTML = `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>`;
      feedback.classList.remove('hidden');
    }
  });
</script>