---
// src/components/Navbar.astro
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-5
         bg-[#FAF4D4] shadow-none"
>
  <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between">

    <!-- Logo -->
    <a
      href="/"
      class="font-lobster text-3xl text-[#660005] tracking-wide hover:text-[#DF8F9C] transition-colors duration-300 relative z-50"
      aria-label="Ana Glaam - Inicio"
    >
      anaglaam
    </a>

    <!-- Links desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {[
        { label: 'Inicio',         href: '#inicio' },
        { label: 'Sobre mí',       href: '#sobre-mi' },
        { label: 'Servicios',      href: '#servicios' },
        { label: 'Portafolio',     href: '#portafolio' },
        { label: 'Stats',          href: '#stats' },
        { label: 'Colaboraciones', href: '#colaboraciones' },
      ].map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="nav-link font-inter text-sm font-medium text-[#1A0000] relative
                   after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px]
                   after:bg-[#660005] after:transition-all after:duration-300
                   hover:after:w-full hover:text-[#660005] transition-colors duration-300"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA desktop -->
    <a
      href="#contacto"
      class="hidden md:inline-flex items-center gap-2 bg-[#660005] text-[#FAF4D4]
             font-inter font-semibold text-sm px-6 py-3 rounded-full
             hover:bg-[#DF8F9C] hover:text-[#1A0000] hover:shadow-lg
             transition-all duration-300 hover:scale-105 active:scale-95"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      ¡Colaboremos!
    </a>

    <!-- Hamburger mobile -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-[5px] relative z-50"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="hamburger-line block w-6 h-[2px] bg-[#660005] rounded transition-all duration-300 origin-center"></span>
      <span class="hamburger-line block w-6 h-[2px] bg-[#660005] rounded transition-all duration-300"></span>
      <span class="hamburger-line block w-6 h-[2px] bg-[#660005] rounded transition-all duration-300 origin-center"></span>
    </button>
  </nav>

  <!-- Mobile menu overlay — z-40 para estar sobre el contenido pero bajo el logo/hamburger -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 z-40 flex flex-col justify-center items-center gap-8
           bg-[#FAF4D4] 
           opacity-0 pointer-events-none transition-all duration-500 translate-y-[-10px]"
  >

    {[
      { label: 'Inicio',         href: '#inicio' },
      { label: 'Sobre mí',       href: '#sobre-mi' },
      { label: 'Servicios',      href: '#servicios' },
      { label: 'Portafolio',     href: '#portafolio' },
      { label: 'Stats',          href: '#stats' },
      { label: 'Colaboraciones', href: '#colaboraciones' },
    ].map(({ label, href }) => (
      <a
        href={href}
        class="mobile-nav-link font-bebas text-4xl text-[#1A0000] tracking-widest
               hover:text-[#660005] transition-colors duration-300"
      >
        {label}
      </a>
    ))}

    <a
      href="#contacto"
      class="mt-4 bg-[#660005] text-[#FAF4D4] font-inter font-semibold
             px-8 py-4 rounded-full text-base hover:bg-[#DF8F9C]
             hover:text-[#1A0000] transition-all duration-300"
    >
      ¡Colaboremos!
    </a>

    <div class="flex gap-6 mt-2">
      <a href="https://instagram.com/anaglaam" target="_blank" rel="noopener noreferrer"
         aria-label="Instagram de Ana Glaam"
         class="text-[#660005] hover:text-[#DF8F9C] transition-colors duration-300">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a href="https://tiktok.com/@anaglam8" target="_blank" rel="noopener noreferrer"
         aria-label="TikTok de Ana Glaam"
         class="text-[#660005] hover:text-[#DF8F9C] transition-colors duration-300">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.53V6.75a4.85 4.85 0 01-1.02-.06z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<script>
  const navbar     = document.getElementById('navbar')!;
  const menuBtn    = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const lines      = menuBtn.querySelectorAll('.hamburger-line');
  let isOpen       = false;

  // Scroll: solo maneja sombra y padding — el fondo ya está fijo en el HTML
  function applyScrollStyles() {
    if (window.scrollY > 20) {
      navbar.classList.add('shadow-[0_2px_20px_rgba(102,0,5,0.1)]', 'py-3');
      navbar.classList.remove('py-5');
    } else if (!isOpen) {
      navbar.classList.remove('shadow-[0_2px_20px_rgba(102,0,5,0.1)]', 'py-3');
      navbar.classList.add('py-5');
    }
  }

  window.addEventListener('scroll', applyScrollStyles);

  function toggleMenu() {
    isOpen = !isOpen;
    menuBtn.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-[-10px]');
      mobileMenu.classList.add('opacity-100', 'translate-y-0');
      (lines[0] as HTMLElement).style.transform = 'rotate(45deg) translate(5px, 5px)';
      (lines[1] as HTMLElement).style.opacity   = '0';
      (lines[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(5px, -5px)';
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none', 'translate-y-[-10px]');
      mobileMenu.classList.remove('opacity-100', 'translate-y-0');
      (lines[0] as HTMLElement).style.transform = '';
      (lines[1] as HTMLElement).style.opacity   = '1';
      (lines[2] as HTMLElement).style.transform = '';
      document.body.style.overflow = '';
      applyScrollStyles();
    }
  }

  menuBtn.addEventListener('click', toggleMenu);

  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => { if (isOpen) toggleMenu(); });
  });
</script>