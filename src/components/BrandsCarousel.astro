---
// src/components/BrandsCarousel.astro
---

<section id="colaboraciones" class="relative py-20 bg-[#F2DFE3] overflow-hidden">

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12" data-aos="fade-up">
      <span class="font-inter text-xs font-semibold tracking-[0.25em] uppercase text-[#DF8F9C]">
        Colaboraciones
      </span>
      <h2 class="font-bebas text-[#1A0000] mt-2 leading-none"
          style="font-size: clamp(2.8rem, 5vw, 4.5rem);">
        Marcas que han <span class="text-[#660005]">confiado en mí</span>
      </h2>
      <p class="font-inter text-[#1A0000]/60 mt-3 max-w-lg mx-auto">
        Y tú puedes ser la siguiente. Hablemos de cómo llevar tu marca al siguiente nivel.
      </p>
    </div>

    <!-- Carrusel de logos -->
    <div class="relative overflow-hidden" data-aos="fade-up" data-aos-delay="100">

      <!-- Fade laterales -->
      <div class="absolute left-0 top-0 h-full w-20 z-10
                  bg-gradient-to-r from-[#F2DFE3] to-transparent pointer-events-none"></div>
      <div class="absolute right-0 top-0 h-full w-20 z-10
                  bg-gradient-to-l from-[#F2DFE3] to-transparent pointer-events-none"></div>

      <div class="flex" style="animation: brandsScroll 20s linear infinite;">
        {Array(3).fill(null).map(() => (
          <div class="flex items-center shrink-0 gap-8 px-4">
            {[
              { name: 'Marca Belleza 1',  emoji: '💄' },
              { name: 'Marca Skincare 2', emoji: '🧴' },
              { name: 'Marca Nails 3',    emoji: '💅' },
              { name: 'Marca Hair 4',     emoji: '🌀' },
              { name: 'Marca Moda 5',     emoji: '👗' },
              { name: 'Marca Premium 6',  emoji: '✨' },
            ].map(({ name, emoji }) => (
              <div class="flex items-center gap-3 bg-white rounded-2xl px-6 py-4 shrink-0
                          shadow-[0_2px_12px_rgba(102,0,5,0.08)]
                          hover:shadow-[0_4px_20px_rgba(102,0,5,0.15)]
                          hover:-translate-y-1 transition-all duration-300 group">
                <span class="text-2xl group-hover:scale-110 transition-transform duration-300">
                  {emoji}
                </span>
                <span class="font-inter font-semibold text-sm text-[#1A0000]/70
                             group-hover:text-[#660005] transition-colors duration-300
                             whitespace-nowrap">
                  {name}
                </span>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!--
      📌 NOTA PARA ANA:
      Reemplaza cada { name, emoji } con los logos reales de tus marcas:
      { name: 'NombreMarca', logo: '/images/logos-marcas/nombre-marca-logo.webp' }
      Y cambia el div de emoji+nombre por:
      <img src={logo} alt={`Logo ${name} - colaboración con Ana Dávila UGC`}
           class="h-8 w-auto object-contain grayscale group-hover:grayscale-0 transition-all" />
    -->

    <!-- CTA -->
    <div class="text-center mt-14" data-aos="fade-up">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-[#660005] text-[#FAF4D4]
               font-inter font-semibold px-8 py-4 rounded-full text-sm
               hover:bg-[#1A0000] transition-all duration-300
               hover:scale-105 active:scale-95
               shadow-[0_4px_20px_rgba(102,0,5,0.3)]"
      >
        Quiero ser la siguiente marca
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes brandsScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>