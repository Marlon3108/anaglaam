---
// src/components/BrandsCarousel.astro

const brands = [
  {
    name: 'hi beauty',
    logo: '/images/logos-marcas/hi-beauty-logo.webp',
    alt: 'Logo Hi Beauty - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'NINE LESS°',
    logo: '/images/logos-marcas/nine-less-logo.webp',
    alt: 'Logo Nine Less - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'PROKPIL',
    logo: '/images/logos-marcas/prokpil-logo.webp',
    alt: 'Logo Prokpil - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'TEMU',
    logo: '/images/logos-marcas/temu-logo.webp',
    alt: 'Logo Temu - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'VT Cosmetics',
    logo: '/images/logos-marcas/vt-cosmetics-logo.webp',
    alt: 'Logo VT Cosmetics - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'Beetles Gel Polish',
    logo: '/images/logos-marcas/beetles-gel-polish-logo.webp',
    alt: 'Logo Beetles Gel Polish - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'AXIS-Y',
    logo: '/images/logos-marcas/axis-y-logo.webp',
    alt: 'Logo AXIS-Y - colaboración con Ana Dávila UGC Creator',
  },
  {
    name: 'Stamped Glorious',
    logo: '/images/logos-marcas/stamped-glorious-logo.webp',
    alt: 'Logo Stamped Glorious - colaboración con Ana Dávila UGC Creator',
  },
];
---

<section id="colaboraciones" class="relative py-20 bg-[#F2DFE3] overflow-hidden">

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12" data-aos="fade-up">
      <span class="font-inter text-xs font-semibold tracking-[0.25em] uppercase text-[#DF8F9C]">
        Colaboraciones
      </span>
      <h2 class="font-bebas text-[#1A0000] mt-2 leading-none"
          style="font-size: clamp(2.8rem, 5vw, 4.5rem);">
        Marcas que han <span class="text-[#660005]">confiado en mí</span>
      </h2>
      <p class="font-inter text-[#1A0000]/60 mt-3 max-w-lg mx-auto">
        Y tú puedes ser la siguiente. Hablemos de cómo llevar tu marca al siguiente nivel.
      </p>
    </div>

    <!-- Carrusel -->
    <div class="relative overflow-hidden" data-aos="fade-up" data-aos-delay="100">

      <!-- Fade laterales -->
      <div class="absolute left-0 top-0 h-full w-24 z-10
                  bg-gradient-to-r from-[#F2DFE3] to-transparent pointer-events-none"></div>
      <div class="absolute right-0 top-0 h-full w-24 z-10
                  bg-gradient-to-l from-[#F2DFE3] to-transparent pointer-events-none"></div>

      <!-- Track — triplicado para loop infinito suave -->
      <div class="flex items-center gap-5 carousel-track">
        {Array(3).fill(null).map(() =>
          brands.map(({ name, logo, alt }) => (
            <div class="brand-card group shrink-0">
              <img
                src={logo}
                alt={alt}
                width="80"
                height="80"
                loading="lazy"
                decoding="async"
                class="w-20 h-20 object-contain
                       grayscale opacity-70
                       group-hover:grayscale-0 group-hover:opacity-100
                       transition-all duration-400"
              />
              <!-- Nombre debajo — visible solo en hover -->
              <span class="absolute -bottom-6 left-1/2 -translate-x-1/2
                           font-inter text-[10px] font-semibold text-[#660005]
                           whitespace-nowrap opacity-0 group-hover:opacity-100
                           transition-opacity duration-300">
                {name}
              </span>
            </div>
          ))
        )}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-14" data-aos="fade-up">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-[#660005] text-[#FAF4D4]
               font-inter font-semibold px-8 py-4 rounded-full text-sm
               hover:bg-[#1A0000] transition-all duration-300
               hover:scale-105 active:scale-95
               shadow-[0_4px_20px_rgba(102,0,5,0.3)]"
      >
        Quiero ser la siguiente marca
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .carousel-track {
    animation: brandsScroll 24s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes brandsScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  .brand-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 1rem;           /* rounded-2xl */
    padding: 1rem;
    width: 7rem;                   /* 112px — cuadrado uniforme */
    height: 7rem;
    box-shadow: 0 2px 12px rgba(102, 0, 5, 0.08);
    transition: all 0.3s ease;
    margin-bottom: 1.5rem;         /* espacio para el label hover */
  }

  .brand-card:hover {
    box-shadow: 0 8px 28px rgba(102, 0, 5, 0.16);
    transform: translateY(-4px);
  }
</style>