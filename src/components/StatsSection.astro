---
// src/components/StatsSection.astro
---

<section id="stats" class="relative py-24 bg-[#660005] overflow-hidden">

  <!-- Decoración fondo -->
  <div class="absolute inset-0 pointer-events-none opacity-10" aria-hidden="true"
       style="background-image: radial-gradient(#FAF4D4 1px, transparent 1px); background-size: 28px 28px;">
  </div>
  <div class="absolute -top-24 -right-24 w-[400px] h-[400px] rounded-full
              bg-[#DF8F9C]/20 blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <span class="font-inter text-xs font-semibold tracking-[0.25em] uppercase text-[#DF8F9C]">
        Números reales
      </span>
      <h2 class="font-bebas text-[#FAF4D4] mt-2 leading-none"
          style="font-size: clamp(2.8rem, 5vw, 4.5rem);">
        El alcance que tu <span class="text-[#DF8F9C]">marca necesita</span>
      </h2>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {[
        { value: 178000, display: '178K',  label: 'Views en TikTok',        suffix: '',  icon: '🎬' },
        { value: 3140,   display: '3.1K',  label: 'Cuentas alcanzadas/mes', suffix: '+', icon: '👁️' },
        { value: 367,    display: '3.67',  label: 'Engagement rate IG',     suffix: '%', icon: '💬' },
        { value: 1500,   display: '1.5K',  label: 'Seguidores Instagram',   suffix: '+', icon: '❤️' },
      ].map(({ display, label, suffix, icon }, i) => (
        <div
          class="bg-[#FAF4D4]/10 backdrop-blur-sm rounded-3xl p-7 text-center
                 border border-[#FAF4D4]/15
                 hover:bg-[#FAF4D4]/15 transition-all duration-300"
          data-aos="fade-up"
          data-aos-delay={i * 100}
        >
          <div class="text-3xl mb-3">{icon}</div>
          <div class="font-bebas text-[#FAF4D4] leading-none mb-1"
               style="font-size: clamp(2.5rem, 5vw, 4rem);">
            <span class="counter" data-target={display}>{display}</span>
            <span class="text-[#DF8F9C]">{suffix}</span>
          </div>
          <p class="font-inter text-[#FAF4D4]/60 text-xs leading-snug">{label}</p>
        </div>
      ))}
    </div>

    <!-- Barra de audiencia -->
    <div
      class="bg-[#FAF4D4]/10 rounded-3xl p-8 border border-[#FAF4D4]/15"
      data-aos="fade-up"
    >
      <p class="font-inter text-xs font-semibold tracking-[0.2em] uppercase
                text-[#DF8F9C] mb-6 text-center">Distribución de audiencia por edad</p>

      <div class="flex flex-col gap-4 max-w-lg mx-auto">
        {[
          { age: '18–24 años', pct: 13.2,  width: 'w-[13%]' },
          { age: '25–34 años', pct: 42.5,  width: 'w-[43%]' },
          { age: '35–44 años', pct: 28.9,  width: 'w-[29%]' },
        ].map(({ age, pct, width }) => (
          <div class="flex items-center gap-4">
            <span class="font-inter text-xs text-[#FAF4D4]/70 w-24 shrink-0">{age}</span>
            <div class="flex-1 bg-[#FAF4D4]/10 rounded-full h-2.5 overflow-hidden">
              <div
                class={`h-full bg-gradient-to-r from-[#DF8F9C] to-[#FAF4D4] rounded-full bar-fill`}
                style={`width: 0%; transition: width 1.5s ease;`}
                data-width={`${pct}%`}
              ></div>
            </div>
            <span class="font-bebas text-[#FAF4D4] text-lg w-12 text-right">{pct}%</span>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-14" data-aos="fade-up">
      <p class="font-playfair italic text-[#FAF4D4]/70 mb-5 text-lg">
        "Tu marca frente a una audiencia real que confía en mis recomendaciones."
      </p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-[#FAF4D4] text-[#660005]
               font-inter font-semibold px-8 py-4 rounded-full text-sm
               hover:bg-[#DF8F9C] transition-all duration-300
               hover:scale-105 active:scale-95
               shadow-[0_4px_20px_rgba(0,0,0,0.2)]"
      >
        Quiero trabajar con Ana
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Animar barras cuando entran en viewport
  const bars = document.querySelectorAll('.bar-fill');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        el.style.width = el.dataset.width || '0%';
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.3 });

  bars.forEach(bar => observer.observe(bar));
</script>